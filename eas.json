{
  "cli": {
    "version": ">= 16.20.4",
    "appVersionSource": "remote"
  },
  "build": {
    "development": {
      "developmentClient": true,
      "distribution": "internal"
    },
    "preview": {
      "distribution": "internal",
      "android": {
        "buildType": "apk"
      }
    },
    "site": {
      "distribution": "internal",
      "android": {
        "buildType": "apk"
      },
      "env": {
        "PAYMENT_PROVIDER": "zarinpal"
      }
    },
    "bazaar": {
      "distribution": "internal",
      "android": {
        "buildType": "apk"
      },
      "env": {
        "PAYMENT_PROVIDER": "bazaar"
      }
    },

    "bazaar-dev": {
      "developmentClient": true,
      "distribution": "internal",
      "android": {
        "buildType": "apk"
      },
      "env": {
        "PAYMENT_PROVIDER": "bazaar"
      }
    },

    "production": {
      "autoIncrement": true
    }
  },
  "submit": {
    "production": {}
  }
}